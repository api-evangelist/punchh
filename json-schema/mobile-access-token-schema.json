{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AccessToken",
  "description": "AccessToken schema from PAR Punchh Mobile API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/punchh/refs/heads/main/json-schema/mobile-access-token-schema.json",
  "type": "object",
  "properties": {
    "token": {
      "type": "string",
      "example": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4"
    },
    "refresh_token": {
      "type": "string",
      "example": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4"
    },
    "seconds_to_expire": {
      "type": "integer",
      "example": "example"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}