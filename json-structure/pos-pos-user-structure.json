{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/punchh/refs/heads/main/json-structure/pos-pos-user-structure.json",
  "name": "PosUser",
  "description": "PosUser schema from PAR Punchh POS and Kiosk API",
  "type": "object",
  "properties": {
    "phone_number": {
      "type": "string",
      "example": "+15551234567"
    },
    "email": {
      "type": "string",
      "example": "jsmith@example.com"
    },
    "first_name": {
      "type": "string",
      "example": "Jane Smith"
    },
    "last_name": {
      "type": "string",
      "example": "Jane Smith"
    },
    "card_number": {
      "type": "string",
      "example": "example"
    },
    "balances": {
      "type": "object",
      "description": "Loyalty point and reward balances."
    }
  }
}