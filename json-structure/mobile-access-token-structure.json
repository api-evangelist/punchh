{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/punchh/refs/heads/main/json-structure/mobile-access-token-structure.json",
  "name": "AccessToken",
  "description": "AccessToken schema from PAR Punchh Mobile API",
  "type": "object",
  "properties": {
    "token": {
      "type": "string",
      "example": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4"
    },
    "refresh_token": {
      "type": "string",
      "example": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4"
    },
    "seconds_to_expire": {
      "type": "int32",
      "example": "example"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}